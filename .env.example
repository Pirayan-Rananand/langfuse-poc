OPENROUTER_API_KEY=sk-or-...

# Cloud SQL (leave blank for local dev — falls back to in-memory)
# Format: postgresql+asyncpg://user:pass@127.0.0.1:5432/moneycoach
# Use Cloud SQL Auth Proxy sidecar for GCP production.
DATABASE_URL=

# Langfuse (dev project)
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...

# Langfuse (prod project — used by GitHub Actions only, not needed locally)
LANGFUSE_PROD_SECRET_KEY=sk-lf-...
LANGFUSE_PROD_PUBLIC_KEY=pk-lf-...

LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_TRACING_ENVIRONMENT="dev"
LANGFUSE_TIMEOUT=30

GITHUB_TOKEN=ghp...
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Evaluation pipeline
EVAL_DATASET_NAME=money-coach-eval-v1
EVAL_PROMOTION_THRESHOLD=1.03
EVAL_JUDGE_MODEL=google/gemini-2.5-flash
